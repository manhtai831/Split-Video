SITE_URL=https://your-domain.com
FILE_RETENTION_DAYS=30

# Basic auth
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-secure-password

# Auth sessions (HMAC signing secret, min 32 chars recommended)
SESSION_SECRET=change-me-to-a-long-random-secret

# Resend email
RESEND_API_KEY=re_xxxxxxxxx
RESEND_FROM_EMAIL=Video Tools <noreply@your-domain.com>

# Time to rescan cache and scan storage
STORAGE_SCAN_INTERVAL_MINUTES=5

# Upload chunk size and TTL
UPLOAD_CHUNK_SIZE_MB=5
UPLOAD_CHUNK_TTL_HOURS=24
UPLOAD_MAX_PARTS=100000

# Maximum number of threads to use for FFmpeg 0 means use fallback 80% CPU cores
FFMPEG_MAX_THREADS=0

# yt-dlp updater (scheduled via robfig/cron in the main process)
YTDLP_UPDATER_BIN=/usr/local/bin/ytdlp-updater
YTDLP_UPDATE_CRON=0 */2 * * *

# YouTube playlist formats/metadata cache TTL (minutes). Expired rows are re-probed via yt-dlp.
YOUTUBE_FORMATS_CACHE_MINUTES=1440
